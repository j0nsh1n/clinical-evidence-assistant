# NCBI E-utilities (PubMed).
# NCBI asks every caller to identify themselves by email.
# An API key is optional but raises the rate limit from 3 to 10 requests/second.
# Get one at: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_EMAIL=you@example.com
NCBI_API_KEY=

# Optional: enables the "Refine with AI" summary (Anthropic API, Claude Sonnet 4.6).
# Left blank, the app uses the rules-based summary. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
