# NCBI E-utilities (PubMed).
# NCBI asks every caller to identify themselves by email.
# An API key is optional but raises the rate limit from 3 to 10 requests/second.
# Get one at: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_EMAIL=you@example.com
NCBI_API_KEY=

# "Refine with AI" summaries. Optional — left unset, the app always uses the
# rules-based summary. LLM_PROVIDER selects a backend: "auto" (default) prefers a
# local Ollama model, then Anthropic; "ollama" or "anthropic" force one.
LLM_PROVIDER=auto

# Local model via Ollama (free, no API key). Start Ollama yourself (`ollama serve`)
# and set OLLAMA_MODEL to a pulled model to enable local AI refine.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=

# Cloud Claude API (optional alternative to Ollama). Get a key at
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
